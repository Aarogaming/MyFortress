{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/app-spec/v1",
  "title": "AppSpec v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "issuedUtc", "name", "features"],
  "properties": {
    "schemaName": { "const": "AppSpec" },
    "schemaVersion": { "const": "1.0.0" },

    "issuedUtc": { "type": "string", "format": "date-time" },

    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },

    "features": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },

    "ui": { "$ref": "#/$defs/ui" },
    "api": { "$ref": "#/$defs/api" },
    "storage": { "$ref": "#/$defs/storage" },

    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nonGoals": {
      "type": "array",
      "items": { "type": "string" }
    },

    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["web", "desktop", "cli"] },
        "notes": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["http", "grpc", "none"] },
        "notes": { "type": "string" }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["sqlite", "postgres", "none"] },
        "notes": { "type": "string" }
      }
    }
  }
}
