{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/research-discovery-request/v1",
  "title": "ResearchDiscoveryRequest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "issuedUtc", "requirements"],
  "properties": {
    "schemaName": { "const": "ResearchDiscoveryRequest" },
    "schemaVersion": { "const": "1.0.0" },

    "issuedUtc": { "type": "string", "format": "date-time" },

    "requirements": { "type": "string", "minLength": 1 },

    "ecosystems": {
      "type": "array",
      "items": { "type": "string", "enum": ["github", "pypi", "npm", "cargo"] }
    },
    "language": { "type": "string" },

    "licenseAllowlist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "maxCandidates": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "minStars": { "type": "integer", "minimum": 0 },
    "updatedSinceUtc": { "type": "string", "format": "date-time" },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    }
  }
}
