{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/weekly-digest/v1",
  "title": "WeeklyDigest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "generatedUtc", "weekOfUtc", "highlights", "actions"],
  "properties": {
    "schemaName": { "const": "WeeklyDigest" },
    "schemaVersion": { "const": "1.0.0" },

    "generatedUtc": { "type": "string", "format": "date-time" },
    "weekOfUtc": { "type": "string", "format": "date" },

    "highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },

    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string", "enum": ["trace_id", "message_id", "log_key"] },
        "id": { "type": "string", "minLength": 1 },
        "note": { "type": "string" }
      }
    }
  }
}
