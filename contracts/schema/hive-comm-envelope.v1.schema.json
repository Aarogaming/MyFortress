{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aas.local/contracts/hive-comm-envelope/v1",
  "title": "HiveCommEnvelope v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaName",
    "schemaVersion",
    "kind",
    "topic",
    "message_id",
    "module_id",
    "event_type",
    "payload",
    "sequence",
    "require_ack",
    "emitted_utc"
  ],
  "properties": {
    "schemaName": { "const": "HiveCommEnvelope" },
    "schemaVersion": { "const": "1.0.0" },
    "kind": { "type": "string" },
    "topic": { "type": "string" },
    "message_id": { "type": "string", "minLength": 1 },
    "module_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "sequence": { "type": "integer", "minimum": 0 },
    "require_ack": { "type": "boolean" },
    "emitted_utc": { "type": "string" },
    "trace_id": { "type": ["string", "null"] },
    "correlation_id": { "type": ["string", "null"] },
    "source": { "type": "object" }
  }
}
