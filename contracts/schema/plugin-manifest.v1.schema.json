{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/plugin-manifest/v1",
  "title": "PluginManifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "name", "version", "entry", "capabilities"],
  "properties": {
    "schemaName": { "const": "PluginManifest" },
    "schemaVersion": { "const": "1.0.0" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "entry": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["plugin", "adapter", "service", "ui"] },
    "enabled": { "type": "boolean" },
    "owner": { "type": "string" },
    "license": { "type": "string" },
    "repository": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://aas.local/contracts/capability/v1" }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "name", "version"],
        "properties": {
          "type": { "type": "string", "enum": ["plugin", "service", "library", "capability"] },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "optional": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    },
    "interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "version"],
        "properties": {
          "type": { "type": "string", "enum": ["http", "grpc", "cli", "ipc", "ws"] },
          "version": { "type": "string" },
          "endpoint": { "type": "string" }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "configSchemaId": { "type": "string", "format": "uri" },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
