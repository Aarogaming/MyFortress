{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/memory-search/v1",
  "title": "MemorySearch v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "issuedUtc",
    "query"
  ],
  "properties": {
    "schemaName": { "const": "MemorySearch" },
    "schemaVersion": { "const": "1.0.0" },
    "issuedUtc": { "type": "string", "format": "date-time" },

    "query": { "type": "string", "minLength": 1 },

    "scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope" }
    },
    "namespaces": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "tagsAny": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tagsAll": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "limit": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "includeExpired": { "type": "boolean" },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "scope": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(global|session:[^\\s]+|task:[^\\s]+|hive:[^\\s]+)$"
    },
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    }
  }
}
