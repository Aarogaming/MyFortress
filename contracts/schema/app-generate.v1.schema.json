{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/app-generate/v1",
  "title": "AppGenerateRequest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "issuedUtc", "spec", "target"],
  "properties": {
    "schemaName": { "const": "AppGenerateRequest" },
    "schemaVersion": { "const": "1.0.0" },
    "issuedUtc": { "type": "string", "format": "date-time" },

    "spec": { "$ref": "#/$defs/appSpec" },

    "target": { "$ref": "#/$defs/target" },
    "mode": { "type": "string", "enum": ["plan_only", "scaffold"] },
    "dryRun": { "type": "boolean" },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    },
    "appSpec": {
      "type": "object",
      "additionalProperties": true
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language"],
      "properties": {
        "language": { "type": "string", "minLength": 1 },
        "framework": { "type": "string" },
        "runtime": { "type": "string" },
        "deployment": { "type": "string" }
      }
    }
  }
}
