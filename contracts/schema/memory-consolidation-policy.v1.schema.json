{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/memory-consolidation-policy/v1",
  "title": "MemoryConsolidationPolicy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "issuedUtc",
    "policyId",
    "enabled",
    "defaults"
  ],
  "properties": {
    "schemaName": { "const": "MemoryConsolidationPolicy" },
    "schemaVersion": { "const": "1.0.0" },

    "issuedUtc": { "type": "string", "format": "date-time" },
    "policyId": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean" },

    "defaults": { "$ref": "#/$defs/defaults" },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    },

    "notes": { "type": "string" },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minItems": { "type": "integer", "minimum": 2, "maximum": 100000 },
        "maxItems": { "type": "integer", "minimum": 2, "maximum": 100000 },
        "maxOutputItems": { "type": "integer", "minimum": 1, "maximum": 1000 },

        "allowDelete": { "type": "boolean" },
        "requireMinConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "requireMinFeedback": { "type": "string", "enum": ["none", "non_negative", "positive"] },
        "denyKeyPrefix": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },

        "outputNamespace": { "type": "string", "minLength": 1 },
        "outputKeyPrefix": { "type": "string", "minLength": 1 },
        "ttlSec": { "type": "integer", "minimum": 1 },

        "consolidationPrompt": { "type": "string" }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match", "apply"],
      "properties": {
        "match": { "$ref": "#/$defs/match" },
        "apply": { "$ref": "#/$defs/defaults" }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scope": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "keyPrefix": { "type": "string", "minLength": 1 }
      }
    }
  }
}
