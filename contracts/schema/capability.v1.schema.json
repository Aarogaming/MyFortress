{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/capability/v1",
  "title": "Capability v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "name", "version"],
  "properties": {
    "schemaName": { "const": "Capability" },
    "schemaVersion": { "const": "1.0.0" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "visibility": { "type": "string", "enum": ["public", "internal"] },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "version", "direction"],
        "properties": {
          "id": { "type": "string", "format": "uri" },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": ["produces", "consumes", "bidirectional"]
          }
        }
      }
    },
    "requires": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "optional": { "type": "boolean" }
        }
      }
    }
  }
}
