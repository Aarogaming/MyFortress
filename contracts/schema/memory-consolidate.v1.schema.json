{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/memory-consolidate/v1",
  "title": "MemoryConsolidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "issuedUtc",
    "scope",
    "namespace"
  ],
  "properties": {
    "schemaName": { "const": "MemoryConsolidate" },
    "schemaVersion": { "const": "1.0.0" },

    "issuedUtc": { "type": "string", "format": "date-time" },

    "scope": { "$ref": "#/$defs/scope" },
    "namespace": { "type": "string", "minLength": 1 },

    "keyPrefix": { "type": "string", "minLength": 1 },
    "policyId": { "type": "string", "minLength": 1 },

    "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "dryRun": { "type": "boolean" },
    "includePlan": { "type": "boolean" },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "scope": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(global|session:[^\\s]+|task:[^\\s]+|hive:[^\\s]+)$"
    },
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    }
  }
}
