{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/inference-backend-run/v1",
  "title": "InferenceBackendRun v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "issuedUtc", "backendId", "openaiBaseUrl", "unitSpec"],
  "properties": {
    "schemaName": { "const": "InferenceBackendRun" },
    "schemaVersion": { "const": "1.0.0" },
    "issuedUtc": { "type": "string", "format": "date-time" },

    "backendId": { "type": "string", "minLength": 1 },
    "openaiBaseUrl": { "type": "string", "minLength": 1 },
    "openaiHeaders": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "setActive": { "type": "boolean", "default": true },

    "unitSpec": { "$ref": "runtime-unit-spec.v1.schema.json" },
    "timeoutSec": { "type": "integer", "minimum": 1 },
    "captureLogs": { "type": "boolean", "default": true },
    "dryRun": { "type": "boolean", "default": false },

    "traceId": { "type": "string", "minLength": 1 },
    "extensions": { "type": "object", "additionalProperties": true }
  }
}
