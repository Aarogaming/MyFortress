{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/memory-upsert/v1",
  "title": "MemoryUpsert v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "issuedUtc",
    "op",
    "scope",
    "namespace",
    "key",
    "value"
  ],
  "properties": {
    "schemaName": { "const": "MemoryUpsert" },
    "schemaVersion": { "const": "1.0.0" },
    "issuedUtc": { "type": "string", "format": "date-time" },

    "op": { "const": "upsert" },

    "scope": { "$ref": "#/$defs/scope" },
    "namespace": { "type": "string", "minLength": 1 },
    "key": { "type": "string", "minLength": 1 },

    "value": { "type": "object" },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "ttlSec": { "type": "integer", "minimum": 1 },

    "expectedRevision": { "type": "integer", "minimum": 0 },
    "idempotencyKey": { "type": "string", "minLength": 1 },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "scope": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(global|session:[^\\s]+|task:[^\\s]+|hive:[^\\s]+)$"
    },
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    }
  }
}
