{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/memory-merge-plan/v1",
  "title": "MemoryMergePlan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "generatedUtc",
    "requestMessageId",
    "scope",
    "namespace",
    "actions"
  ],
  "properties": {
    "schemaName": { "const": "MemoryMergePlan" },
    "schemaVersion": { "const": "1.0.0" },

    "generatedUtc": { "type": "string", "format": "date-time" },
    "requestMessageId": { "type": "string", "minLength": 1 },

    "scope": { "$ref": "#/$defs/scope" },
    "namespace": { "type": "string", "minLength": 1 },

    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "scope": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(global|session:[^\\s]+|task:[^\\s]+|hive:[^\\s]+)$"
    },
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "scope", "namespace", "key"],
      "properties": {
        "event": { "type": "string", "enum": ["ADD", "UPDATE", "DELETE", "NONE"] },

        "scope": { "$ref": "#/$defs/scope" },
        "namespace": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },

        "oldSummary": { "type": "string" },
        "newSummary": { "type": "string" },

        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reason": { "type": "string" },

        "oldRevision": { "type": "integer", "minimum": 0 },
        "newRevision": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
