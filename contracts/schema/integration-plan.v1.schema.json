{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/integration-plan/v1",
  "title": "IntegrationPlan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "generatedUtc", "requestMessageId", "target", "components", "steps"],
  "properties": {
    "schemaName": { "const": "IntegrationPlan" },
    "schemaVersion": { "const": "1.0.0" },

    "generatedUtc": { "type": "string", "format": "date-time" },
    "requestMessageId": { "type": "string", "minLength": 1 },

    "target": { "$ref": "#/$defs/target" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/component" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },

    "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "$ref": "#/$defs/risk" } },
    "licenseSummary": { "$ref": "#/$defs/licenseSummary" },
    "notes": { "type": "string" },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language"],
      "properties": {
        "language": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string" },
        "framework": { "type": "string" },
        "repoRoot": { "type": "string" }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ecosystem", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "ecosystem": { "type": "string", "enum": ["github", "pypi", "npm", "cargo"] },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "license": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "add_dependency",
            "add_config",
            "add_adapter",
            "add_code",
            "add_tests",
            "run_command",
            "verify",
            "document"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "details": { "type": "string" },
        "command": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "dependsOn": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "description"],
      "properties": {
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "description": { "type": "string", "minLength": 1 },
        "mitigation": { "type": "string" }
      }
    },
    "licenseSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": { "type": "boolean" },
        "licenses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      }
    }
  }
}
