{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/research-analysis-result/v1",
  "title": "ResearchAnalysisResult v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "generatedUtc", "requestMessageId", "inputs", "evaluations"],
  "properties": {
    "schemaName": { "const": "ResearchAnalysisResult" },
    "schemaVersion": { "const": "1.0.0" },

    "generatedUtc": { "type": "string", "format": "date-time" },
    "requestMessageId": { "type": "string", "minLength": 1 },

    "inputs": { "$ref": "#/$defs/inputs" },

    "evaluations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evaluation" }
    },

    "recommended": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation" }
    },

    "warnings": { "type": "array", "items": { "type": "string" } },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirements"],
      "properties": {
        "requirements": { "type": "string", "minLength": 1 },
        "discoveryRequestMessageId": { "type": "string", "minLength": 1 },
        "discoveryResultMessageId": { "type": "string", "minLength": 1 },
        "ecosystems": {
          "type": "array",
          "items": { "type": "string", "enum": ["github", "pypi", "npm", "cargo"] }
        },
        "language": { "type": "string" },
        "licenseAllowlist": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "candidateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ecosystem", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "ecosystem": { "type": "string", "enum": ["github", "pypi", "npm", "cargo"] },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "license": { "type": "string" },
        "repoUrl": { "type": "string", "format": "uri" }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "decision"],
      "properties": {
        "candidate": { "$ref": "#/$defs/candidateRef" },
        "decision": { "type": "string", "enum": ["adopt", "reject", "investigate"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },

        "license": { "$ref": "#/$defs/licenseEval" },
        "security": { "$ref": "#/$defs/securityEval" },
        "quality": { "$ref": "#/$defs/qualityEval" },
        "compatibility": { "$ref": "#/$defs/compatibilityEval" },

        "rationale": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "licenseEval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "declared": { "type": "string" },
        "allowed": { "type": "boolean" },
        "requiresAttribution": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "securityEval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "risk": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/securityFinding" }
        },
        "notes": { "type": "string" }
      }
    },
    "securityFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "title"],
      "properties": {
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "title": { "type": "string", "minLength": 1 },
        "id": { "type": "string" },
        "details": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "qualityEval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maintained": { "type": "boolean" },
        "hasTests": { "type": "boolean" },
        "hasCI": { "type": "boolean" },
        "stars": { "type": "integer", "minimum": 0 },
        "lastUpdatedUtc": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "compatibilityEval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": { "type": "string" },
        "runtime": { "type": "string" },
        "platforms": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateId", "reason"],
      "properties": {
        "candidateId": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    }
  }
}
