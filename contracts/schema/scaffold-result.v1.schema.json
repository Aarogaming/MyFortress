{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/scaffold-result/v1",
  "title": "ScaffoldResult v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "generatedUtc", "requestMessageId", "status"],
  "properties": {
    "schemaName": { "const": "ScaffoldResult" },
    "schemaVersion": { "const": "1.0.0" },

    "generatedUtc": { "type": "string", "format": "date-time" },
    "requestMessageId": { "type": "string", "minLength": 1 },

    "status": { "type": "string", "enum": ["planned", "scaffolded", "failed", "skipped"] },

    "plan": { "type": "array", "items": { "type": "string" } },
    "files": { "type": "array", "items": { "$ref": "#/$defs/file" } },
    "commands": { "type": "array", "items": { "type": "string" } },
    "artifactRef": { "type": "string", "minLength": 1 },

    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": { "type": "object", "additionalProperties": true }
  },
  "oneOf": [
    { "required": ["plan"] },
    { "required": ["files"] },
    { "required": ["artifactRef"] }
  ],
  "$defs": {
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "content"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "mode": { "type": "string" },
        "operation": { "type": "string", "enum": ["create", "update", "delete"] }
      }
    }
  }
}
