{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/memory-health/v1",
  "title": "MemoryHealth v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "generatedUtc", "status", "provider"],
  "properties": {
    "schemaName": { "const": "MemoryHealth" },
    "schemaVersion": { "const": "1.0.0" },

    "generatedUtc": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["ok", "degraded", "down"] },

    "provider": { "$ref": "#/$defs/providerRef" },

    "store": { "$ref": "#/$defs/storeStats" },
    "embeddings": { "$ref": "#/$defs/embeddingStats" },
    "notes": { "type": "string" },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    },
    "storeStats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "items": { "type": "integer", "minimum": 0 },
        "scopes": { "type": "integer", "minimum": 0 },
        "namespaces": { "type": "integer", "minimum": 0 },
        "bytesApprox": { "type": "integer", "minimum": 0 },
        "durable": { "type": "boolean" }
      }
    },
    "embeddingStats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "lastOkUtc": { "type": "string", "format": "date-time" },
        "lastErrorUtc": { "type": "string", "format": "date-time" },
        "lastError": { "type": "string" }
      }
    }
  }
}
