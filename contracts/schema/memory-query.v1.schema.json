{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/memory-query/v1",
  "title": "MemoryQuery v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "issuedUtc",
    "scope",
    "namespace"
  ],
  "properties": {
    "schemaName": { "const": "MemoryQuery" },
    "schemaVersion": { "const": "1.0.0" },
    "issuedUtc": { "type": "string", "format": "date-time" },

    "scope": { "$ref": "#/$defs/scope" },
    "namespace": { "type": "string", "minLength": 1 },

    "key": { "type": "string", "minLength": 1 },
    "keyPrefix": { "type": "string", "minLength": 1 },

    "tagsAny": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tagsAll": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "includeExpired": { "type": "boolean" },
    "limit": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "cursor": { "type": "string", "minLength": 1 },

    "source": { "$ref": "#/$defs/providerRef" },
    "traceId": { "type": "string", "minLength": 1 },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "scope": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(global|session:[^\\s]+|task:[^\\s]+|hive:[^\\s]+)$"
    },
    "providerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hiveId", "instanceId", "componentId"],
      "properties": {
        "hiveId": { "type": "string", "minLength": 1 },
        "instanceId": { "type": "string", "minLength": 1 },
        "componentId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "string", "minLength": 1 }
      }
    }
  },
  "oneOf": [
    {
      "required": ["key"],
      "not": { "required": ["keyPrefix"] }
    },
    {
      "required": ["keyPrefix"],
      "not": { "required": ["key"] }
    },
    {
      "not": { "anyOf": [{ "required": ["key"] }, { "required": ["keyPrefix"] }] }
    }
  ]
}
