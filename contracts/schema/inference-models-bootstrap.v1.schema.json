{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/inference-models-bootstrap/v1",
  "title": "InferenceModelsBootstrap v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaName", "schemaVersion", "issuedUtc"],
  "properties": {
    "schemaName": { "const": "InferenceModelsBootstrap" },
    "schemaVersion": { "const": "1.0.0" },
    "issuedUtc": { "type": "string", "format": "date-time" },

    "purpose": {
      "type": "string",
      "enum": ["chat", "embeddings", "both"],
      "default": "both"
    },
    "prefer": {
      "type": "string",
      "enum": ["small", "quality"],
      "default": "small"
    },
    "maxSizeGb": { "type": "number", "minimum": 0 },

    "roots": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "extensions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "maxDepth": { "type": "integer", "minimum": 1, "default": 6 },
    "maxEntries": { "type": "integer", "minimum": 1, "default": 500 },

    "apply": { "type": "boolean", "default": false },
    "rollbackOnFailure": { "type": "boolean", "default": true },

    "backendTypeOverride": {
      "type": "string",
      "enum": ["stub", "llama_cpp_python_server", "llama_cpp_server"]
    },
    "autoPort": { "type": "boolean", "default": true },
    "chatPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "embeddingsPort": { "type": "integer", "minimum": 1, "maximum": 65535 },

    "waitReadySec": { "type": "integer", "minimum": 0, "default": 3 },
    "setActiveChat": { "type": "boolean", "default": true },
    "setActiveEmbeddings": { "type": "boolean", "default": false },

    "traceId": { "type": "string", "minLength": 1 },
    "extensionsObj": { "type": "object", "additionalProperties": true }
  }
}
