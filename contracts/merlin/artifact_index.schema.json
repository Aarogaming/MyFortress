{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/merlin/artifact-index/v1",
  "title": "MerlinArtifactIndex v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "generated_utc", "run_id", "artifacts"],
  "properties": {
    "schema_name": { "const": "MerlinArtifactIndex" },
    "schema_version": { "const": 1 },
    "generated_utc": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    }
  },
  "$defs": {
    "tier": { "type": "string", "enum": ["Tier0", "Tier1", "Tier2"] },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "size_bytes", "sha256", "tier"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "tier": { "$ref": "#/$defs/tier" },
        "content_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
