{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/merlin/distill-event/v1",
  "title": "MerlinDistillEvent v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_type",
    "user_prompt",
    "attachments",
    "tools",
    "teacher_responses",
    "selection",
    "labels",
    "metadata"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "task_type": {
      "type": "string",
      "enum": ["chat", "reasoning", "code", "format", "vision", "tool"]
    },
    "system_prompt": { "type": ["string", "null"] },
    "user_prompt": { "type": "string" },
    "context": { "type": ["string", "null"] },
    "attachments": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachment" }
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    },
    "teacher_responses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/teacher_response" }
    },
    "selection": { "$ref": "#/$defs/selection" },
    "labels": { "$ref": "#/$defs/labels" },
    "metadata": { "$ref": "#/$defs/metadata" }
  },
  "$defs": {
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "uri", "mime_type", "sha256"],
      "properties": {
        "type": { "type": "string", "enum": ["image", "file", "audio", "video"] },
        "uri": { "type": "string", "minLength": 1 },
        "mime_type": { "type": "string", "minLength": 1 },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "input_schema"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "input_schema": { "type": ["object", "null"] }
      }
    },
    "teacher_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "response",
        "prompt_tokens",
        "completion_tokens",
        "latency_ms",
        "checks",
        "judge_scores"
      ],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "response": { "type": "string" },
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "latency_ms": { "type": "number", "minimum": 0 },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "total"],
          "properties": {
            "passed": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          }
        },
        "judge_scores": {
          "type": "array",
          "items": { "$ref": "#/$defs/judge_score" }
        },
        "error": { "type": "string" }
      }
    },
    "judge_score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "score", "adheres", "notes"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "score": { "type": "number" },
        "adheres": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["winner_model", "response", "rationale"],
      "properties": {
        "winner_model": { "type": "string", "minLength": 1 },
        "response": { "type": "string" },
        "rationale": { "type": "string" }
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["difficulty", "style", "safety"],
      "properties": {
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "style": {
          "type": "string",
          "enum": ["concise", "detailed", "structured", "creative", "neutral"]
        },
        "safety": { "type": "string", "enum": ["safe", "needs_review"] }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "source", "prompt_set", "run_id", "created_at"],
      "properties": {
        "domain": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "prompt_set": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
