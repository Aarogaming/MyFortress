{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/contracts/merlin/action-plan/v1",
  "title": "MerlinActionPlan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "plan_id",
    "created_utc",
    "intent",
    "risk",
    "actions"
  ],
  "properties": {
    "schema_name": { "const": "MerlinActionPlan" },
    "schema_version": { "const": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "created_utc": { "type": "string", "format": "date-time" },
    "intent": { "type": "string", "minLength": 1 },
    "risk": { "$ref": "#/$defs/risk" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/action" }
    },
    "deferred_fetch": { "$ref": "#/$defs/deferred_fetch" }
  },
  "$defs": {
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_write", "protected_branch", "network"],
      "properties": {
        "repo_write": { "type": "boolean" },
        "protected_branch": { "type": "boolean" },
        "network": { "type": "boolean" }
      }
    },
    "action_type": {
      "type": "string",
      "enum": [
        "GET_STATUS",
        "SYNC_REQUEST",
        "FETCH_LOG_TAIL",
        "ENQUEUE_JOB",
        "CANCEL_JOB",
        "SET_PRIORITY",
        "REQUEST_APPROVAL"
      ]
    },
    "action_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_type"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_type": { "$ref": "#/$defs/action_type" },
        "rationale": { "type": "string" },
        "params": { "type": "object" }
      }
    },
    "action": {
      "oneOf": [
        { "$ref": "#/$defs/action_get_status" },
        { "$ref": "#/$defs/action_sync_request" },
        { "$ref": "#/$defs/action_fetch_log_tail" },
        { "$ref": "#/$defs/action_enqueue_job" },
        { "$ref": "#/$defs/action_cancel_job" },
        { "$ref": "#/$defs/action_set_priority" },
        { "$ref": "#/$defs/action_request_approval" }
      ]
    },
    "action_get_status": {
      "allOf": [
        { "$ref": "#/$defs/action_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["params"],
          "properties": {
            "action_type": { "const": "GET_STATUS" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "maxProperties": 0
            }
          }
        }
      ]
    },
    "action_sync_request": {
      "allOf": [
        { "$ref": "#/$defs/action_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["params"],
          "properties": {
            "action_type": { "const": "SYNC_REQUEST" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["target"],
              "properties": {
                "target": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    },
    "action_fetch_log_tail": {
      "allOf": [
        { "$ref": "#/$defs/action_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["params"],
          "properties": {
            "action_type": { "const": "FETCH_LOG_TAIL" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["lines"],
              "properties": {
                "lines": { "type": "integer", "minimum": 1, "maximum": 10000 },
                "source": { "type": "string", "minLength": 1 },
                "since_utc": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      ]
    },
    "action_enqueue_job": {
      "allOf": [
        { "$ref": "#/$defs/action_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["params"],
          "properties": {
            "action_type": { "const": "ENQUEUE_JOB" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["job_id"],
              "properties": {
                "job_id": { "type": "string", "minLength": 1 },
                "queue": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    },
    "action_cancel_job": {
      "allOf": [
        { "$ref": "#/$defs/action_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["params"],
          "properties": {
            "action_type": { "const": "CANCEL_JOB" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["job_id"],
              "properties": {
                "job_id": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    },
    "action_set_priority": {
      "allOf": [
        { "$ref": "#/$defs/action_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["params"],
          "properties": {
            "action_type": { "const": "SET_PRIORITY" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["job_id", "priority"],
              "properties": {
                "job_id": { "type": "string", "minLength": 1 },
                "priority": { "type": "integer", "minimum": 0, "maximum": 100 }
              }
            }
          }
        }
      ]
    },
    "action_request_approval": {
      "allOf": [
        { "$ref": "#/$defs/action_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["params"],
          "properties": {
            "action_type": { "const": "REQUEST_APPROVAL" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["approval_kind", "message"],
              "properties": {
                "approval_kind": {
                  "type": "string",
                  "enum": [
                    "repo_write",
                    "protected_branch",
                    "network",
                    "other"
                  ]
                },
                "message": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    },
    "deferred_fetch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "when_online": {
          "type": "array",
          "items": { "$ref": "#/$defs/deferred_fetch_action" }
        }
      }
    },
    "deferred_fetch_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_type", "params"],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "action_type": {
          "type": "string",
          "enum": ["GET_STATUS", "SYNC_REQUEST", "FETCH_LOG_TAIL"]
        },
        "params": { "type": "object" },
        "rationale": { "type": "string" }
      }
    }
  }
}
