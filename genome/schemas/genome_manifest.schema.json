{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/genome/schemas/genome_manifest.schema.json",
  "title": "AAS Genome Manifest",
  "description": "Canonical Agent-Zero DNA contract for generating and evolving federation repos.",
  "type": "object",
  "required": [
    "schema_version",
    "genome_version",
    "repo_identity",
    "runtime_profiles",
    "kernel",
    "contracts",
    "reflexes",
    "persona",
    "control_plane_slice",
    "capability_catalog",
    "delegation_policy",
    "lifecycle"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "genome_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "repo_identity": {
      "type": "object",
      "required": ["name", "designation", "directive"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "designation": { "type": "string", "minLength": 1 },
        "directive": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "runtime_profiles": {
      "type": "object",
      "required": ["default", "supported"],
      "properties": {
        "default": {
          "type": "string",
          "enum": ["solo", "federated"]
        },
        "supported": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["solo", "federated"]
          }
        }
      },
      "additionalProperties": false
    },
    "kernel": {
      "type": "object",
      "required": ["kernel_api_version", "boot_entry", "plugin_loader", "health_checks"],
      "properties": {
        "kernel_api_version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "boot_entry": { "type": "string", "minLength": 1 },
        "plugin_loader": { "type": "string", "minLength": 1 },
        "health_checks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "contracts": {
      "type": "object",
      "required": ["manifest_schema", "interop_schema", "lifecycle_schema", "lease_schema"],
      "properties": {
        "manifest_schema": { "type": "string", "minLength": 1 },
        "interop_schema": { "type": "string", "minLength": 1 },
        "lifecycle_schema": { "type": "string", "minLength": 1 },
        "lease_schema": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "reflexes": {
      "type": "object",
      "required": ["startup", "runtime", "failure"],
      "properties": {
        "startup": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "runtime": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "failure": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "persona": {
      "type": "object",
      "required": ["tone", "quirks", "values", "autonomy_level", "state_model"],
      "properties": {
        "tone": { "type": "string", "minLength": 1 },
        "quirks": { "type": "string", "minLength": 1 },
        "values": { "type": "string", "minLength": 1 },
        "autonomy_level": { "type": "integer", "minimum": 1, "maximum": 5 },
        "state_model": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "control_plane_slice": {
      "type": "object",
      "required": ["observer_enabled", "mutator_mode", "lease_required"],
      "properties": {
        "observer_enabled": { "type": "boolean" },
        "mutator_mode": {
          "type": "string",
          "enum": ["disabled", "eligible", "holder_only"]
        },
        "lease_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "capability_catalog": {
      "type": "object",
      "required": ["core_runtime", "core_control", "domain"],
      "properties": {
        "core_runtime": {
          "type": "array",
          "items": { "type": "string", "pattern": "^core\\.runtime\\..+" }
        },
        "core_control": {
          "type": "array",
          "items": { "type": "string", "pattern": "^core\\.control\\..+" }
        },
        "domain": {
          "type": "array",
          "items": { "type": "string", "pattern": "^domain\\..+" }
        }
      },
      "additionalProperties": false
    },
    "delegation_policy": {
      "type": "object",
      "required": ["states", "default_state", "federation_fallback"],
      "properties": {
        "states": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["active", "dormant", "delegated", "retired"]
          }
        },
        "default_state": {
          "type": "string",
          "enum": ["active", "dormant", "delegated", "retired"]
        },
        "federation_fallback": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["birth", "training", "stabilization", "specialization", "federation", "evolution"],
      "properties": {
        "birth": { "type": "string", "minLength": 1 },
        "training": { "type": "string", "minLength": 1 },
        "stabilization": { "type": "string", "minLength": 1 },
        "specialization": { "type": "string", "minLength": 1 },
        "federation": { "type": "string", "minLength": 1 },
        "evolution": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
