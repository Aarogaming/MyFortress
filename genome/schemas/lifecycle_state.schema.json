{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/genome/schemas/lifecycle_state.schema.json",
  "title": "AAS Agent Lifecycle State",
  "description": "Runtime lifecycle state for a generated agent repo.",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "genome_version",
    "current_stage",
    "status",
    "mode",
    "promotion",
    "updated_at_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "genome_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "current_stage": {
      "type": "string",
      "enum": [
        "birth",
        "training",
        "stabilization",
        "specialization",
        "federation",
        "evolution"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "quarantine_pending",
        "active",
        "degraded",
        "retired"
      ]
    },
    "mode": {
      "type": "string",
      "enum": ["solo", "federated"]
    },
    "promotion": {
      "type": "object",
      "required": ["gates_required", "gates_passed", "auditor"],
      "properties": {
        "gates_required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "gates_passed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "auditor": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "updated_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
