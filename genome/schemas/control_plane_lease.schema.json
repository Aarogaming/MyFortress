{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aas.local/genome/schemas/control_plane_lease.schema.json",
  "title": "AAS Control Plane Lease",
  "description": "Single-writer lease for control-plane mutation safety across observer-capable agents.",
  "type": "object",
  "required": [
    "schema_version",
    "lease_id",
    "resource",
    "holder_repo",
    "holder_agent_id",
    "mode",
    "issued_at_utc",
    "expires_at_utc",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "lease_id": {
      "type": "string",
      "minLength": 1
    },
    "resource": {
      "type": "string",
      "enum": ["federation.control_plane"]
    },
    "holder_repo": {
      "type": "string",
      "minLength": 1
    },
    "holder_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["observer", "mutator"]
    },
    "issued_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "released", "expired", "revoked"]
    },
    "renewable": {
      "type": "boolean",
      "default": true
    },
    "epoch": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    }
  },
  "additionalProperties": false
}
