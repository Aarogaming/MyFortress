# HomeGateway configuration
HOMEGATEWAY_HOST=0.0.0.0
HOMEGATEWAY_PORT=8100
HOMEGATEWAY_LOG_LEVEL=info
HOMEGATEWAY_API_KEY=changeme
HOMEGATEWAY_REQUEST_TIMEOUT=5.0
HOMEGATEWAY_MAX_RETRIES=2
HOMEGATEWAY_SNAPSHOT_CACHE_TTL=10.0
HOMEGATEWAY_USE_SERVICE=false
HOMEGATEWAY_STRUCTURED_LOGGING=false

# Home Assistant
HOMEGATEWAY_HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOMEGATEWAY_HOME_ASSISTANT_TOKEN=
HOMEGATEWAY_HOME_ASSISTANT_ENTITIES=sensor.temp,sensor.humidity
HOMEGATEWAY_HOME_ASSISTANT_TIMEOUT=5.0
HOMEGATEWAY_HOME_ASSISTANT_VERIFY_SSL=true

# Frigate
HOMEGATEWAY_FRIGATE_URL=http://frigate.local:5000
HOMEGATEWAY_FRIGATE_API_KEY=
HOMEGATEWAY_FRIGATE_CAMERAS=front,back
HOMEGATEWAY_FRIGATE_TIMEOUT=5.0
